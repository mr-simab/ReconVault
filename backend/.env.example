# Backend service config
NODE_ENV=development
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info

# Firebase Realtime Database
# Leave blank to run in degraded local mode.
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Alternative: paste the complete Firebase service account JSON into one line.
# If this is set, the split Firebase credential fields above are not required.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional OSINT API keys
HIBP_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
GITHUB_TOKEN=
SHODAN_API_KEY=
SECURITYTRAILS_API_KEY=
BUILTWITH_API_KEY=
WAPPALYZER_API_KEY=
GOOGLE_VISION_API_KEY=
OCR_SPACE_API_KEY=
FACEPP_API_KEY=
FACEPP_API_SECRET=

# AI orchestration provider
# Leave LLM_PROVIDER empty to use deterministic fallback planning.
# Supported values: openai, anthropic, gemini, openrouter, ollama
LLM_PROVIDER=
LLM_MODEL=
LLM_REQUEST_TIMEOUT_MS=45000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Optional MCP gateway server mapping.
# Example:
# MCP_GATEWAY_SERVERS_JSON={"Recon MCP":{"baseUrl":"http://127.0.0.1:5000","endpointTemplate":"/mcp/tools/recon/{tool}"}}
MCP_GATEWAY_SERVERS_JSON=
EXECUTION_MAX_PARALLEL_STEPS=4
